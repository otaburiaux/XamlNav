<Window x:Class="XamlNav.RenameInlinePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Deactivated="Window_Deactivated"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        FocusManager.FocusedElement="{Binding ElementName=NameTextBox}">
    <Window.Resources>
        <!-- VS theme colors: defaults are dark-theme fallbacks, overridden at runtime by ApplyVsThemeColors() -->
        <SolidColorBrush x:Key="PopupBg" Color="#2D2D30"/>
        <SolidColorBrush x:Key="PopupBorder" Color="#007ACC"/>
        <SolidColorBrush x:Key="PopupText" Color="#DCDCDC"/>
        <SolidColorBrush x:Key="InputBg" Color="#3F3F46"/>
        <SolidColorBrush x:Key="InputBorder" Color="#555555"/>
        <SolidColorBrush x:Key="InputAccent" Color="#007ACC"/>
        <SolidColorBrush x:Key="HoverBg" Color="#3F3F46"/>
        <SolidColorBrush x:Key="GrayText" Color="#888888"/>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="{DynamicResource PopupText}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PopupBg}"
            BorderBrush="{DynamicResource PopupBorder}"
            BorderThickness="1"
            CornerRadius="3"
            MinWidth="280" MaxWidth="480">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="8" ShadowDepth="2"/>
        </Border.Effect>
        <StackPanel>
            <!-- Input row -->
            <Grid Margin="6,6,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NameTextBox"
                         Grid.Column="0"
                         Background="{DynamicResource InputBg}"
                         Foreground="{DynamicResource PopupText}"
                         CaretBrush="{DynamicResource PopupText}"
                         SelectionBrush="{DynamicResource InputAccent}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource InputBorder}"
                         Padding="4,3"
                         FontFamily="Consolas"
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         PreviewKeyDown="NameTextBox_PreviewKeyDown"
                         TextChanged="NameTextBox_TextChanged"/>

                <!-- Apply button (✓) -->
                <Button x:Name="ApplyButton"
                        Grid.Column="1"
                        Style="{StaticResource IconButton}"
                        ToolTip="Apply rename (Enter)"
                        Margin="4,0,0,0"
                        Click="Apply_Click">
                    <TextBlock Text="✓" Foreground="#4EC94E" FontSize="14" FontWeight="Bold"/>
                </Button>

                <!-- Cancel button (✗) -->
                <Button x:Name="CancelButton"
                        Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        ToolTip="Cancel (Escape)"
                        Margin="2,0,0,0"
                        Click="Cancel_Click">
                    <TextBlock Text="✗" Foreground="#F14C4C" FontSize="14" FontWeight="Bold"/>
                </Button>
            </Grid>

            <!-- Hint row -->
            <TextBlock x:Name="HintLabel"
                       Margin="8,0,8,5"
                       FontSize="10"
                       Foreground="{DynamicResource GrayText}"
                       Text="↵ apply  ·  Shift+↵ preview  ·  Esc cancel"/>

            <!-- Preview panel (collapsed by default) -->
            <Border x:Name="PreviewPanel"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource InputBg}"
                    BorderThickness="0,1,0,0"
                    Margin="0,2,0,0">
                <StackPanel Margin="8,6,8,6">
                    <TextBlock x:Name="PreviewHeader"
                               Foreground="{DynamicResource GrayText}"
                               FontSize="10"
                               Margin="0,0,0,4"/>
                    <ItemsControl x:Name="PreviewList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="{DynamicResource PopupText}"
                                           Text="{Binding}"
                                           Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
